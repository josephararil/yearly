{
  // Project name → becomes yearly.<your-subdomain>.workers.dev
  "name": "yearly",

  // Pins runtime behaviour to a date so future platform changes don't alter your app.
  // Today's date is fine.
  "compatibility_date": "2026-06-08",

  // The folder to upload and serve at the site root.
  "assets": {
    "directory": "./public"
  }
}